{
  "manifest_version": 3,
  "name": "PhishGuard",
  "description": "Detects phishing URLs using machine learning. Checks the current page and tells you if it's safe.",
  "version": "1.0",
  "permissions": ["activeTab", "tabs"],
  "host_permissions": ["https://*.onrender.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  }
}
